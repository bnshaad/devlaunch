rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function ownsExistingResource() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncomingResource() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function usernameIsValid(username) {
      return username is string
        && username.matches('^[a-z0-9_-]{3,20}$');
    }

    function isPublicPortfolio(uid) {
      return exists(/databases/$(database)/documents/portfolios/$(uid))
        && get(/databases/$(database)/documents/portfolios/$(uid)).data.isPublic == true;
    }

    function nullableString(value) {
      return value == null || value is string;
    }

    function safeUserCreate(uid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'photoURL',
          'photoPublicId',
          'photoUpdatedAt',
          'username',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && nullableString(request.resource.data.displayName)
        && safeUserCreatePhotoValues(uid)
        && request.resource.data.username == null
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function safeUsernameUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'username',
          'updatedAt'
        ])
        && resource.data.username == null
        && usernameIsValid(request.resource.data.username);
    }

    function safeUserPhotoPublicId(uid) {
      return request.resource.data.photoPublicId is string
        && request.resource.data.photoPublicId == 'devlaunch/profile-photos/' + uid + '/avatar';
    }

    function safeUserPhotoURL() {
      return request.resource.data.photoURL is string
        && request.resource.data.photoURL.matches('^https://res\\.cloudinary\\.com/.+');
    }

    function safeUserPhotoValues(uid) {
      return (
          request.resource.data.photoURL == null
          && request.resource.data.photoPublicId == null
        )
        || (
          request.resource.data.photoURL == ''
          && request.resource.data.photoPublicId == ''
        )
        || (
          safeUserPhotoURL()
          && safeUserPhotoPublicId(uid)
        );
    }

    function safeUserCreatePhotoValues(uid) {
      return (
          request.resource.data.photoURL == null
          && request.resource.data.photoPublicId == null
          && request.resource.data.photoUpdatedAt == null
        )
        || (
          request.resource.data.photoURL == ''
          && request.resource.data.photoPublicId == ''
          && request.resource.data.photoUpdatedAt == null
        )
        || (
          safeUserPhotoURL()
          && safeUserPhotoPublicId(uid)
          && request.resource.data.photoUpdatedAt == request.time
        );
    }

    function safeUserPhotoUpdate(uid) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'photoURL',
          'photoPublicId',
          'photoUpdatedAt',
          'updatedAt'
        ])
        && safeUserPhotoValues(uid)
        && request.resource.data.photoUpdatedAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function safePortfolioKeys() {
      return request.resource.data.keys().hasOnly([
        'userId',
        'fullName',
        'headline',
        'bio',
        'location',
        'email',
        'githubUrl',
        'linkedinUrl',
        'websiteUrl',
        'skills',
        'isPublic',
        'createdAt',
        'updatedAt'
      ]);
    }

    function safePortfolioTextFields() {
      return request.resource.data.fullName is string
        && request.resource.data.headline is string
        && request.resource.data.bio is string
        && request.resource.data.location is string
        && request.resource.data.email is string
        && request.resource.data.githubUrl is string
        && request.resource.data.linkedinUrl is string
        && request.resource.data.websiteUrl is string;
    }

    function safePortfolioValues(uid) {
      return safePortfolioKeys()
        && request.resource.data.userId == uid
        && safePortfolioTextFields()
        && request.resource.data.skills is list
        && request.resource.data.skills.size() <= 20
        && request.resource.data.isPublic is bool;
    }

    function safePortfolioCreate(uid) {
      return safePortfolioValues(uid)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function safePortfolioUpdate(uid) {
      return safePortfolioValues(uid)
        && resource.data.userId == uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;
    }

    // User profile metadata is owner-private unless the user has published a
    // portfolio. The current public portfolio page reads users/{uid} for avatar
    // metadata after username resolution.
    match /users/{uid} {
      allow read: if isOwner(uid)
        || isPublicPortfolio(uid);

      allow create: if isOwner(uid)
        && safeUserCreate(uid);

      allow update: if isOwner(uid)
        && resource.data.uid == uid
        && request.resource.data.uid == uid
        && (
          safeUsernameUpdate()
          || safeUserPhotoUpdate(uid)
        );

      allow delete: if false;
    }

    // Public username lookup for /dev/{username}. Writes are limited to the
    // authenticated uid in the mapping, preventing username takeover.
    match /usernames/{username} {
      allow read: if usernameIsValid(username);

      allow create: if signedIn()
        && usernameIsValid(username)
        && !exists(/databases/$(database)/documents/usernames/$(username))
        && request.resource.data.uid == request.auth.uid;

      allow update: if signedIn()
        && usernameIsValid(username)
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;

      allow delete: if signedIn()
        && resource.data.uid == request.auth.uid;
    }

    // Portfolio documents are keyed by owner uid. Public reads are allowed only
    // when the owner explicitly publishes the portfolio.
    match /portfolios/{uid} {
      allow read: if isOwner(uid)
        || resource.data.isPublic == true;

      allow create: if isOwner(uid)
        && safePortfolioCreate(uid);

      allow update: if isOwner(uid)
        && safePortfolioUpdate(uid);

      allow delete: if isOwner(uid)
        && resource.data.userId == uid;
    }

    // Projects are top-level documents with a userId owner field. Public reads
    // are tied to the owner's published portfolio so saved dashboard projects
    // can appear on /dev/{username}; the featured flag only affects ordering.
    match /projects/{projectId} {
      allow read: if ownsExistingResource()
        || isPublicPortfolio(resource.data.userId);

      allow create: if ownsIncomingResource();

      allow update: if ownsExistingResource()
        && request.resource.data.userId == resource.data.userId;

      allow delete: if ownsExistingResource();
    }

    // Internship/application tracker data is private to the authenticated owner.
    match /applications/{applicationId} {
      allow read: if ownsExistingResource();

      allow create: if ownsIncomingResource();

      allow update: if ownsExistingResource()
        && request.resource.data.userId == resource.data.userId;

      allow delete: if ownsExistingResource();
    }

    // Default deny for every collection or document not explicitly modeled.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
